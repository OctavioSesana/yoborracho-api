# Copiá este archivo a ".env" y completá los valores

# Cadena de conexión a PostgreSQL
DATABASE_URL=postgres://yoborracho:yoborracho@localhost:5432/yoborracho

# En true solo para Postgres administrado (Render, Railway, Supabase...), que
# exige SSL en la conexión. En local/Docker Compose dejalo en false.
DATABASE_SSL=false

# Secreto para firmar los tokens JWT (usá un valor largo y aleatorio en producción)
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=7d

# Puerto donde corre la API
PORT=3001

# Origen permitido para CORS (la URL del frontend)
CORS_ORIGIN=http://localhost:5173

NODE_ENV=development

# Cuánto esperamos (en ms) antes de recordarle al conductor que confirme su regreso
# a casa, si pidió el Uber/remis desde la app pero no volvió a cerrar el viaje.
# Por defecto 3 minutos (bueno para probar); en producción convendría algo como 20-30 min.
REGRESO_RECORDATORIO_MS=180000
