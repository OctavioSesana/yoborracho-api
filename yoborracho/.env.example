# Copiá este archivo a ".env" en yoborracho/ y completá los valores.

# API key de Google Maps propia, con Maps JavaScript API + Geocoding API +
# Directions API habilitadas en Google Cloud Console, y restringida por
# referrer HTTP a los dominios donde vaya a correr la app (localhost en
# desarrollo, el dominio real una vez desplegada).
VITE_GOOGLE_MAPS_API_KEY=

# URL del backend. En desarrollo con Docker Compose ya viene seteada en
# docker-compose.yml — estos valores son para correr el frontend suelto
# (npm run dev, sin Docker) o para apuntar a un backend desplegado.
VITE_API_BASE_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
